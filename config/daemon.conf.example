# Example configuration for the template daemon.
# Copy this file to /etc/parser-template/daemon.conf or set DAEMON_CONFIG
# to another path before starting the service.

APP_NAME="parser-template"
RUN_DIR="/tmp/parser-template"
LOG_DIR="/tmp/parser-template/log"
COMMAND_FIFO="${RUN_DIR}/commands.fifo"
RESPONSE_DIR="${RUN_DIR}/responses"
STATE_FILE="${RUN_DIR}/state.env"
DAEMON_LOG="${LOG_DIR}/daemon.log"
PROTOCOL_VERSION="1"
REQUEST_TIMEOUT_SECONDS="10"
TUI_REFRESH_SECONDS="2"
GUI_DIALOG_TOOL="auto"
WEBUI_TITLE="Parser Template WebUI"
PROTOCOL_FORMAT="json"
PROTOCOL_SCHEMA_DIR="/opt/parser-template/protocol/schemas"
PROTOCOL_EXAMPLES_DIR="/opt/parser-template/protocol/examples"
MEDICAL_PROTOCOL_PROFILE="fhir"
PROTOCOL_TRANSPORT="fifo"
PROTOCOL_RUNTIME="bash-linux"

# Raspberry Pi swarm topology.
# Copy this file on every RPi and change RPI_NODE_NAME/RPI_NODE_ROLE to match
# the physical device. Exactly one node should keep RPI_NODE_ROLE="main";
# the remaining nodes should use RPI_NODE_ROLE="worker" and communicate with
# RPI_MAIN_DAEMON_HOST:RPI_MAIN_DAEMON_PORT through their local daemons.
RPI_SWARM_ENABLED="true"
RPI_NODE_NAME="rpi-main"
RPI_NODE_ROLE="main"
RPI_MAIN_DAEMON_NAME="rpi-main"
RPI_MAIN_DAEMON_HOST="192.168.1.10"
RPI_MAIN_DAEMON_PORT="8701"
RPI_MAIN_DAEMON_ENDPOINT="tcp://${RPI_MAIN_DAEMON_HOST}:${RPI_MAIN_DAEMON_PORT}"
RPI_LOCAL_DAEMON_BIND_HOST="0.0.0.0"
RPI_LOCAL_DAEMON_BIND_PORT="8701"

# Inventory of Raspberry Pi nodes in the swarm. Keep addresses static through
# DHCP reservations or static network configuration so worker daemons always
# know where to reach the main daemon.
RPI_SWARM_NODES="rpi-main=192.168.1.10:8701,rpi-worker-01=192.168.1.11:8701,rpi-worker-02=192.168.1.12:8701,rpi-worker-03=192.168.1.13:8701"
RPI_WORKER_DAEMON_ENDPOINTS="rpi-worker-01=tcp://192.168.1.11:8701,rpi-worker-02=tcp://192.168.1.12:8701,rpi-worker-03=tcp://192.168.1.13:8701"
