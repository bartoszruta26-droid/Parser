{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/parser-template/daemon-message.schema.json",
  "title": "Parser Template Daemon Message",
  "type": "object",
  "required": ["protocol", "request_id", "source", "command", "payload"],
  "additionalProperties": false,
  "properties": {
    "protocol": {
      "type": "string",
      "description": "Protocol version used by the daemon contract.",
      "pattern": "^[0-9]+(\\.[0-9]+)?$"
    },
    "request_id": {
      "type": "string",
      "description": "Unique request identifier generated by the client.",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "source": {
      "type": "string",
      "description": "Client family sending the message.",
      "enum": ["cli", "tui", "gui", "webui", "frontend", "backend", "api", "medical", "test"]
    },
    "command": {
      "type": "string",
      "description": "Command name handled by the daemon.",
      "enum": ["ping", "status", "frontend.event", "backend.job", "medical.message", "shutdown"]
    },
    "payload": {
      "type": "object",
      "description": "Command-specific business payload. Keep frontend logic thin; validate in daemon/backend modules."
    },
    "meta": {
      "type": "object",
      "description": "Optional transport, auth, trace and compatibility metadata.",
      "additionalProperties": true,
      "properties": {
        "timestamp_utc": {"type": "string", "format": "date-time"},
        "correlation_id": {"type": "string"},
        "content_type": {"type": "string"},
        "schema": {"type": "string"}
      }
    }
  }
}
